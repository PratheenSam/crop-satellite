# Microsoft Planetary Computer (No credentials required)
# If using Sentinel Hub, uncomment below:
# SENTINELHUB_CLIENT_ID=your_id_here
# SENTINELHUB_CLIENT_SECRET=your_secret_here

# Database Connection (Neon/Postgres)
DATABASE_URL=postgresql://user:password@hostname:5432/dbname?sslmode=require

# Administration
SEED_ADMIN_KEY=your_secret_seed_key_here
